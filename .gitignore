# Node dependencies — restored via `npm install`, never committed.
node_modules/

# Local backups
*.bak

# Local secrets (none expected, defensive)
.env
.env.local
.env.*.local

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Build artifacts (no current build step; pre-empting future tooling)
dist/
build/
.cache/

# Cloudflare Wrangler local state, if used
.wrangler/

# Claude Code per-user / per-session config (the project-level launch.json IS committed).
.claude/settings.local.json
.claude/.local/

# Lexi deterministic event log — operational forensics data, grows per run.
knowledge-graph-agent/log/

.dev.vars*
!.dev.vars.example
!.env.example
